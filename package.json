{
  "name": "mad-mall-production",
  "version": "0.1.0",
  "private": true,
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:madmall": "turbo dev --filter=madmall",
    "build:madmall": "turbo build --filter=madmall",
    "check": "npx ultracite@latest check",
    "check:governance": "tsx scripts/check-governance.ts",
    "fix": "npx ultracite@latest fix",
    "test": "turbo test",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "npx npm-check-updates --deep -u -x recharts && pnpm install",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "cd packages/database && npx prisma format && npx prisma generate && npx prisma db push",
    "seed": "cd packages/database && tsx prisma/seed.ts",
    "clean": "git clean -xdf node_modules",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.6",
    "@biomejs/biome": "2.4.4",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.6.3",
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "ultracite": "6.3.9",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.2"
  },
  "pnpm": {
    "overrides": {
      "parse5": "^7.2.1",
      "next": "16.0.10",
      "react-dom": "19.2.4",
      "@babel/core": "7.28.5"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react-dom": "19.2.4",
        "@babel/core": "7.28.5"
      }
    }
  },
  "type": "module"
}
